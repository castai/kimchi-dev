{
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"outDir": "./dist"
	},
	"include": ["**/*.ts", "types/**/*.d.ts"],
	"exclude": ["**/*.test.ts", "dist"]
}
